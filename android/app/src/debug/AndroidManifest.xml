<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- The INTERNET permission is required for development. Specifically,
         the Flutter tool needs it to communicate with the running application
         to allow setting breakpoints, to provide hot reload, etc.
    -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <application
        android:usesCleartextTraffic="true"
        android:networkSecurityConfig="@xml/network_security_config">
        <!--
          Keep debug launch path stable for flutter run. Dynamic icon aliases can be
          toggled to disabled on device and then flutter run cannot resolve launcher.
        -->
        <activity android:name=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Remove dynamic icon aliases from debug merged manifest. -->
        <activity-alias android:name=".MainActivityAliasOrigin" tools:node="remove" />
        <activity-alias android:name=".MainActivityAliasQuality" tools:node="remove" />
        <activity-alias android:name=".MainActivityAliasPixel" tools:node="remove" />
        <activity-alias android:name=".MainActivityAliasCloud" tools:node="remove" />
        <activity-alias android:name=".MainActivityAliasNeon" tools:node="remove" />
        <activity-alias android:name=".MainActivityAliasVaporwave" tools:node="remove" />
        <activity-alias android:name=".MainActivityAliasChina" tools:node="remove" />
        <activity-alias android:name=".MainActivityAliasChengdu" tools:node="remove" />
        <activity-alias android:name=".MainActivityAliasAnimation" tools:node="remove" />
        <activity-alias android:name=".MainActivityAliasSweet" tools:node="remove" />
    </application>
</manifest>
